Passo 2: Pseudocódigo (Portugol)
algoritmo "TriagemHospital"

var
idade: inteiro
dor: inteiro
temperatura: real
respiracao: caractere

inicio

escreva("Digite a idade do paciente: ")
leia(idade)

escreva("Digite o nível de dor (0 a 10): ")
leia(dor)

escreva("Digite a temperatura corporal: ")
leia(temperatura)

escreva("Possui dificuldade respiratória? (S/N): ")
leia(respiracao)

se (idade < 0) ou (dor < 0) ou (dor > 10) então
    escreva("ERRO: Dados inválidos")
senao

    se (respiracao = "S") então
        escreva("PRIORIDADE MÁXIMA")
        escreva("Atendimento imediato")

    senao

        se (dor >= 8) ou (temperatura >= 39) então
            escreva("PRIORIDADE ALTA")

        senao

            se (idade >= 60) então
                escreva("PRIORIDADE MÉDIA")

            senao
                escreva("PRIORIDADE BAIXA")
            fimse

        fimse

    fimse

fimse

fimalgoritmo
