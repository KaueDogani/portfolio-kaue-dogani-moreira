def analisar_clima():

  soma_temperaturas = 0.0

  dias_quentes = 0

  alerta_extremo = False



  for dia in range(1, 8):

    temp = 0.0

    while True:

      try:

        temp_input = input(f"Digite a temperatura do dia {dia}: ")

        temp = float(temp_input.replace(',', '.')) # Replace comma with dot for float conversion

        break # Exit loop if input is valid

      except ValueError:

        print("Entrada inválida. Por favor, digite um número para a temperatura.")



    soma_temperaturas += temp



    if temp > 35.0:

      dias_quentes += 1



    if temp > 45.0 or temp < -5.0:

      alerta_extremo = True



  media = soma_temperaturas / 7



  print(f"\nMédia semanal: {media:.2f}")

  print(f"Dias acima de 35°C: {dias_quentes}")



  if alerta_extremo:

    print("CUIDADO: Condições climáticas perigosas detectadas!")

  else:

    print("Clima dentro da normalidade operacional.")





# Executar a função

analisar_clima()



